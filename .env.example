# Stripe webhook signing secret (from Stripe Dashboard → Developers → Webhooks)
# Looks like: whsec_...
STRIPE_WEBHOOK_SECRET=

# Resend API key (https://resend.com) — looks like: re_...
RESEND_API_KEY=

# Sender address
# For testing you can use: Omjori <onboarding@resend.dev>
# For production: verify your domain in Resend, then e.g. أكاديمية أم جوري <hello@omjori.online>
EMAIL_FROM=Omjori <onboarding@resend.dev>
